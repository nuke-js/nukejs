{
    "compilerOptions": {
        "outDir": "./dist",
        "emitDeclarationOnly": true,
        "declaration": true,
        "target": "es2022",
        "jsx": "react-jsx",
        "module": "es2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "allowJs": false,
        "noEmit": false,
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "src/**/*",
        "tests/**/*"
    ],
    "exclude": [
        "tests",
        "examples"
    ]
}